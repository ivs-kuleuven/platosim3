    "ax.plot(phase * period, map_params[\"rvphase\"], color=\"C1\", lw=1)\n",
    "ax.set_ylim(-110, 110)\n",
    "ax.set_ylabel(\"radial velocity [m/s]\")\n",
    "ax.set_xlabel(\"phase [days]\")\n",
    "\n",
