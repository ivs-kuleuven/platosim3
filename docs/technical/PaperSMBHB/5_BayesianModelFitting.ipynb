  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Model Doppler boosting"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 28,
   "metadata": {},
   "outputs": [],
   "source": [
    "with pm.Model() as model:\n",
    "    \n",
    "    # Parameters\n",
    "    logK = pm.Uniform(\n",
    "        \"logK\", \n",
    "        lower=0,\n",
    "        upper=np.log(200),\n",
    "        initval=np.log(0.5 * (np.max(flux) - np.min(flux))),\n",
    "    )\n",
    "    logP = pm.Uniform(\n",
    "        \"logP\", \n",
    "        lower=0, \n",
    "        upper=np.log(1500), \n",
    "        initval=np.log(T))\n",
    "    phi = pm.Uniform(\n",
    "        \"phi\", \n",
    "        lower=0, \n",
    "        upper=2*np.pi, \n",
    "        initval=0.1)\n",
    "\n",
    "    # Parameterize the eccentricity using:\n",
    "    #  h = sqrt(e) * sin(w)\n",
    "    #  k = sqrt(e) * cos(w)\n",
    "    h, k = xo.unit_disk(\"h\", \"k\", initval=np.array([0.7, 0.06]))\n",
    "    e = pm.Deterministic(\"e\", h**2 + k**2)\n",
    "    w = pm.Deterministic(\"w\", pt.arctan2(k, h))\n",
    "\n",
    "    # RV signal\n",
    "    flux_trend = pm.Normal(\"flux_trend\", mu=0.0, sigma=10.0, initval=0.0)\n",
    "\n",
    "    # Deterministic transformations\n",
    "    n = 2 * np.pi * pt.exp(-logP)\n",
    "    P = pm.Deterministic(\"P\", pt.exp(logP))\n",
    "    K = pm.Deterministic(\"K\", pt.exp(logK))\n",
    "    cosw = pt.cos(w)\n",
    "    sinw = pt.sin(w)\n",
    "    t0 = (phi + w) / n\n",
    "\n",
    "    # The RV model\n",
    "    M = n * time - (phi + w)\n",
    "    bkg = pm.Deterministic(\"bkg\", flux_trend * time)\n",
    "\n",
    "    # This is the line that uses the custom Kepler solver\n",
    "    f = xo.orbits.get_true_anomaly(M, e + pt.zeros_like(M))\n",
    "    flux_model = pm.Deterministic(\"flux_model\", bkg + K * (cosw * (pt.cos(f) + e) - sinw * pt.sin(f)) )\n",
    "\n",
    "    # Condition on the observations\n",
    "    pm.Normal(\"obs\", mu=flux_model, sigma=flux_err, observed=flux)\n",
    "\n",
    "    # Compute the phased RV signal\n",
    "    phase = np.linspace(0, 1, 500)\n",
    "    M_pred = 2 * np.pi * phase - (phi + w)\n",
    "    f_pred = xo.orbits.get_true_anomaly(M_pred, e + pt.zeros_like(M_pred))\n",
    "    flux_phase = pm.Deterministic(\"flux_phase\", K * (cosw * (pt.cos(f_pred) + e) - sinw * pt.sin(f_pred)))"
   ]
  },
