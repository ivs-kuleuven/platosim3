    "ax.set_ylabel(\"radial velocity [m/s]\")\n",
    "ax.set_xlabel(\"time [days]\")\n",
    "\n",
    "ax = axes[1]\n",
    "ax.errorbar(t % period, rv - map_params[\"bkg\"], yerr=rv_err, fmt=\".k\")\n",
    "ax.set_ylabel(\"radial velocity [m/s]\")\n",
    "ax.set_xlabel(\"phase [days]\")\n",
    "\n",
    "bkg = trace.posterior[\"bkg\"].values\n",
