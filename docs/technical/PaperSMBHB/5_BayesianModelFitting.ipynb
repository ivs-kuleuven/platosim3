    "for ind in np.random.randint(np.prod(bkg.shape[:2]), size=25):\n",
    "    i = np.unravel_index(ind, bkg.shape[:2])\n",
    "    axes[0].plot(t, bkg[i], color=\"C0\", lw=1, alpha=0.3)\n",
    "    axes[1].plot(phase * period, rvphase[i], color=\"C1\", lw=1, alpha=0.3)\n",
    "\n",
    "axes[0].set_ylim(-110, 110)\n",
    "axes[1].set_ylim(-110, 110)\n",
    "\n",
    "plt.tight_layout()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "# Spikey modelling\n",
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "metadata": {},
   "outputs": [],
   "source": [
    "filename = 'spikey_mag16'\n",
    "\n",
    "# Load light curve\n",
    "df = pd.read_feather(sdir / f'finals/lc_{filename}.ftr')\n",
    "df = df.dropna()\n",
    "# df = df.iloc[::1]\n",
    "time = df.time.to_numpy()\n",
    "flux = (df.flux.to_numpy() - 1) * 1e3\n",
    "time -= np.mean(time)\n",
    "flux_err = 10 * np.ones(len(flux))\n",
    "\n",
    "# Load variable source\n",
    "varfile = vdir / 'varsource_spikey_fiducial.txt'\n",
    "dv = pd.read_csv(varfile, sep=' ', names=['time', 'dmag'])\n",
    "dv['flux'] = (10**(-dv.dmag/2.5) - 1) * 1e3\n",
    "dv['time'] /= 86400\n",
    "dv.time -= np.mean(dv.time) #- 48 #+ (dv.time.max()-t.max()))\n",
    "dv = dv.loc[::144]\n",
    "\n",
    "yr = 31557600\n",
    "z = 0.926\n",
    "P = 1.144 * yr / 86400\n",
    "T = P * (1 + z)\n",
    "e = 0.524\n",
    "w = 1.477\n",
    "h = np.sqrt(e) * np.sin(w)\n",
    "k = np.sqrt(e) * np.cos(w)\n",
    "\n",
    "T += 15\n",
    "phase_t = (time % T) / T \n",
    "phase_v = (dv.time % T) / T"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "metadata": {},
   "outputs": [
    {
     "data": {
