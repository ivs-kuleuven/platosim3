    "# Get pattern\n",
    "dex_df = np.array([ut.findNearestIndex(df.freq, f_i[i]) for i in range(dp.N_modes[0])])\n",
    "dex_dm = np.array([ut.findNearestIndex(dm.freq, f_i[i]) for i in range(dp.N_modes[0])])\n",
    "df0 = df.loc[dex_df].reset_index(drop=True)\n",
