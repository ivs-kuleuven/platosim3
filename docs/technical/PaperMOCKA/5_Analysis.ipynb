    "# LOAD STARID=3 FOR SPB AFFOGATO SAMPLE\n",
    "df = lc.data()\n",
    "time = df.time / 86400\n",
    "flux = (df.flux - 1) * 1e4\n",
    "from platosim.noise import DFTpower\n",
    "fn = 5\n",
    "df = np.diff(time)[0] * 0.1\n",
    "freq0, ampl0 = DFTpower(time, flux, f0=0, fn=fn, df=df)\n",
    "per = 1 / df0.freq.to_numpy()"
   ]
