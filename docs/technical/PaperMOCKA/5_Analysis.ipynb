    "\n",
    "# Correct for gamma factor\n",
    "df.ampl /= 2.2\n",
    "\n",
    "# Convert dmag to ppm\n",
    "df.ampl = (1 - ut.fromMagToFlux(df.ampl)) * 1e6\n",
