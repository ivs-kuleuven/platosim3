    "ax.plot(xx_lower, mk.WD_lower(xx_lower), ':', c='royalblue')\n",
    "\n",
    "# Plot sdBV and WD\n",
    "ax.plot(dt_sdb.BP_RP, dt_sdb.Mg, 'b.')\n",
    "ax.plot(dt_wd.BP_RP, dt_wd.Mg, 'c.')\n",
    "\n",
    "# Plot interconnection\n",
