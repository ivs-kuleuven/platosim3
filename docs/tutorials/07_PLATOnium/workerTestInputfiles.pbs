#!/bin/bash

#PBS -l nodes=1:ppn=2:pmem=1gb
#PBS -l walltime=00:00:01
#PBS -N workerTestInputfiles
#PBS -A default_project
#PBS -M -m abe

cd $PBS_O_WORKDIR

module purge
module restore enviroment-PlatoSim3

PLATO_DIR = $VSC_DATA/PlatoSim3

./$PLATO_DIR/build/platosim $PLATO_DIR/input.yaml $VSC_DATA/output.hdf5
